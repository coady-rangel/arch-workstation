# =====================================
# Environment Variables
# =====================================

# Remove duplicate PATH entries while preserving their order
PATH="$(awk -v RS=: '
    length($0) && !seen[$0]++ {
        printf "%s%s", separator, $0
        separator = ":"
    }
' <<< "$PATH")"

# Add ~/.local/bin if it is not already present
case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) PATH="$HOME/.local/bin:$PATH" ;;
esac

export PATH
